<Window x:Class="cybersecurity_awareness_chatbot_p2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cybersecurity_awareness_chatbot_p2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid> <!-- start of parent -->
        
        <!-- grid page for logo -->
        <Grid> <!-- start of logo grid -->
            
            <!-- image logo displaying-->
            <Image  
                Source="/logo.jpeg"
                Height="250"
                Width="400"
                Margin="0,0,0,150"
                />
            
            <!-- button to start Valerie -->
            <Button  
                Height="50"
                Width="200"
                Content="Start Valerie"
                Margin="0,300,0,0"
                />
            

        </Grid><!-- end of logo grid -->
        
    </Grid> <!-- end of parent -->
</Window>
